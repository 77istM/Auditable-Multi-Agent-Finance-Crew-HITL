# ── LLM (Groq Cloud — console.groq.com) ──────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ── Stripe (Test Mode — dashboard.stripe.com/test/apikeys) ───────────────────
# Restricted key with "Refunds: Write" permission
STRIPE_SECRET_KEY=rk_test_your_stripe_restricted_key_here

# ── TrueLayer Sandbox (console.truelayer.com) ─────────────────────────────────
# Omit both values to run in mock/offline mode
TRUELAYER_CLIENT_ID=your_truelayer_client_id_here
TRUELAYER_CLIENT_SECRET=your_truelayer_client_secret_here

# ── LangSmith Observability (smith.langchain.com — free tier) ─────────────────
# Set LANGSMITH_API_KEY to enable full agent tracing; leave blank to disable.
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=finance-refund-agent
