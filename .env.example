# ── LLM (Groq Cloud — console.groq.com) ──────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ── Stripe (Test Mode — dashboard.stripe.com/test/apikeys) ───────────────────
# Restricted key with "Refunds: Write" permission
STRIPE_SECRET_KEY=rk_test_your_stripe_restricted_key_here

# ── TrueLayer Sandbox (console.truelayer.com) ─────────────────────────────────
# Omit both values to run in mock/offline mode
TRUELAYER_CLIENT_ID=your_truelayer_client_id_here
TRUELAYER_CLIENT_SECRET=your_truelayer_client_secret_here

# ── LangSmith Observability (smith.langchain.com — free tier) ─────────────────
# Set LANGSMITH_API_KEY to enable full agent tracing; leave blank to disable.
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=finance-refund-agent

# ── PostgreSQL / Neon (neon.tech — free tier) ─────────────────────────────────
# Leave blank to use the local SQLite fallback (audit.db).
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=

# ── Notifications (all channels are optional — only configured ones fire) ─────
# ntfy.sh — zero-signup push notifications (https://ntfy.sh)
# Pick any unique topic name; share the same name in your ntfy app subscription.
NTFY_TOPIC=

# Slack Incoming Webhook — Settings → Integrations → Incoming Webhooks
SLACK_WEBHOOK_URL=

# Discord Webhook — Server Settings → Integrations → Webhooks
DISCORD_WEBHOOK_URL=

# Gmail SMTP — use a 16-character App Password (not your login password):
# Google Account → Security → 2-Step Verification → App passwords
SMTP_EMAIL=
SMTP_APP_PASSWORD=
NOTIFY_EMAIL=                   # defaults to SMTP_EMAIL if blank

# ── Streamlit app URL (included in notifications so operator can click through) -
STREAMLIT_APP_URL=https://yourapp.streamlit.app
